# Formularz kontaktowy — wysyłka maili przez Resend (https://resend.com).
# Skopiuj ten plik do `.env.local` i uzupełnij. Bez tych zmiennych formularz
# nadal działa (zgłoszenia są logowane po stronie serwera), ale maile nie wychodzą.

# Klucz API z panelu Resend. Po jego dodaniu maile zaczynają wychodzić automatycznie.
RESEND_API_KEY=

# Adres, NA KTÓRY trafiają zgłoszenia z formularza.
CONTACT_TO=kontakt@samorzad.ue.wroc.pl

# Adres nadawcy. Musi być z domeny zweryfikowanej w Resend.
# Do testów można użyć: Formularz SSUEW <onboarding@resend.dev>
CONTACT_FROM=Formularz SSUEW <onboarding@resend.dev>
